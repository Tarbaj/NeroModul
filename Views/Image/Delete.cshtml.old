@using System.Web.Mvc
@using DotNetNuke.Web.Mvc.Helpers
@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<picturpictur.Models.UserImage>

<div class="dnnForm">
    <h2 class="dnnFormSectionHead" style="color: #cc0000;">Confirm Deletion</h2>
    <p>Are you sure you want to delete this image? This action cannot be undone.</p>

    @using (Html.BeginForm("Delete", "Image", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.ImageId)

        <div style="margin-bottom: 20px;">
            <img src="/LinkClick.aspx?fileid=@Model.FileId&portalid=@Dnn.PortalSettings.PortalId" style="width: 200px;" />
        </div>

        <button type="submit" class="dnnPrimaryAction">Yes, Delete Image</button>
        <a href="@Url.Action("Selected", "Image", new { id = Model.ImageId })" class="dnnSecondaryAction">Cancel</a>
    }
</div>