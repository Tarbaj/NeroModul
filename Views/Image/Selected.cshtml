@using DotNetNuke.Services.FileSystem
@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<picturpictur.Models.UserImage>

@{
    var file = FileManager.Instance.GetFile(Model.FileId);
    var imageUrl = file != null ? FileManager.Instance.GetUrl(file) : "";
}

<div class="dnnForm">
    <h2 class="dnnFormSectionHead">Kép részletei</h2>

    <div style="display: flex; gap: 30px; align-items: flex-start; padding: 20px;">
        <div class="img-preview">
            <img src="@imageUrl"
                 alt="Kiválasztott kép"
                 style="max-width: 600px; border: 8px solid @Model.TopColorHex; box-shadow: 0 4px 8px rgba(0,0,0,0.2);" />
        </div>

        <div class="img-meta">
            <h3>Domináns szín: <span>@Model.TopColor</span></h3>

            <div style="width: 120px; height: 120px; background-color: @Model.TopColorHex; border: 2px solid #333; border-radius: 4px;"></div>
            <p style="margin-top: 5px; color: #666;">Hex kód: @Model.TopColorHex</p>

            <div style="margin-top: 40px;">
                <a href="@Url.Action("Delete", "Image", new { id = Model.ImageId })"
                   class="dnnSecondaryAction"
                   onclick="return confirm('Biztosan törölni szeretnéd ezt a képet?');">Kép törlése</a>

                <br /><br />

                <a href="@Url.Action("Index", "Image")" class="dnnTertiaryAction">← Vissza a listához</a>
            </div>
        </div>
    </div>
</div>