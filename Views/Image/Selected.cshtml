@using DotNetNuke.Services.FileSystem
@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<picturpictur.Models.UserImage>
@using Hotcakes.Commerce.Catalog
@using Hotcakes.Commerce
@{
    var hccApp = HotcakesApplication.Current;

    var product = hccApp.CatalogServices.Products.Find(Model.Bvin);
}
@{
    var file = FileManager.Instance.GetFile(Model.FileId);
    var imageUrl = file != null ? FileManager.Instance.GetUrl(file) : "";
}

<div class="pictur-shell">
    <header class="pictur-page-head">
        <div>
            <p class="pictur-kicker">Részletek</p>
            <h1>Kép elemzése</h1>
        </div>
        <a href="@Url.Action("Index", "Image")" class="pictur-button pictur-button-secondary">
            Vissza a listához
        </a>
    </header>

    <div class="pictur-detail-layout">
        <figure class="pictur-detail-figure" style="border-color: @Model.TopColorHex;">
            <img src="@imageUrl" alt="Kiválasztott kép" />
        </figure>

        <aside class="pictur-detail-panel">
            <p class="pictur-panel-label">Elemzett színek (Domináns & Alternatív)</p>
            <div class="pictur-colors-row">
                <div class="pictur-color-readout pictur-color-block">
                    <span class="pictur-large-swatch" style="background-color: @Model.TopColorHex;"></span>
                    <div>
                        <strong>@Model.TopColor</strong><br />
                        <span style="opacity: 0.7;">@Model.TopColorHex</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.AltColorHex))
                {
                    <div class="pictur-color-readout pictur-color-block">
                        <span class="pictur-large-swatch" style="background-color: @Model.AltColorHex;"></span>
                        <div>
                            <strong>@Model.AltColor</strong><br />
                            <span style="opacity: 0.7;">@Model.AltColorHex</span>
                        </div>
                    </div>
                }
            </div>

            <div class="pictur-meta-group">
                <p class="pictur-panel-label">Javasolt termékek</p>
                <div class="pictur-products-row">
                    <div class="pictur-product-item">
                        <a href="//nerokozmetika.hu/#/products/@Model.Bvin">
                            <img class="prod-image" src="/Portals/0/hotcakes/data/products/@Model.Bvin/small/@Model.ImageFileSmall" alt="Domináns termék" />
                        </a>
                    </div>
                    <div class="pictur-product-item">
                        <a href="//nerokozmetika.hu/#/products/@Model.AltBvin">
                            <img class="prod-image" src="/Portals/0/hotcakes/data/products/@Model.AltBvin/small/@Model.AltImageFileSmall" alt="Alternatív termék" />
                        </a>
                    </div>
                </div>
            </div>

            <div class="pictur-detail-actions">
                <a href="@Url.Action("Delete", "Image", new { id = Model.ImageId })"
                   class="pictur-button pictur-button-danger">
                    Kép törlése
                </a>
            </div>
        </aside>
    </div>
</div>