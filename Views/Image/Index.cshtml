@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<IEnumerable<picturpictur.Models.UserImage>>

<div class="pictur-container">
    <div class="dnnForm">
        <h2 class="dnnFormSectionHead">Feltöltött képek</h2>
        <div style="margin-bottom: 20px;">
            <a href="@Url.Action("Edit", "Image")" class="dnnPrimaryAction">Új kép feltöltése</a>
        </div>

        <div style="display: flex; flex-wrap: wrap; gap: 15px;">
            @foreach (var img in Model)
            {
                <div style="border: 1px solid #ccc; padding: 10px; width: 150px; text-align: center; position: relative;">
                    <a href="@Url.Action("Selected", "Image", new { id = img.ImageId })">
                        <img src="/LinkClick.aspx?fileid=@img.FileId&portalid=@Dnn.PortalSettings.PortalId"
                             style="width: 130px; height: 130px; object-fit: cover;" />
                    </a>
                    <div style="height: 10px; margin-top: 5px; background-color: @img.TopColorHex;" title="Top szín: @img.TopColorHex"></div>
                </div>
            }
        </div>
    </div>
</div>