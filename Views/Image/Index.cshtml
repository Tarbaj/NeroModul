@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<IEnumerable<picturpictur.Models.UserImage>>
@using DotNetNuke.Services.FileSystem

<div class="pictur-shell">
    <header class="pictur-page-head">
        <div>
            <p class="pictur-kicker">Galéria</p>
            <h1>Feltöltött képek</h1>
        </div>
        <a href="@Url.Action("Edit", "Image")" class="pictur-button pictur-button-primary">
            Új kép feltöltése
        </a>
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="pictur-grid">
            @foreach (var img in Model)
            {
                var file = FileManager.Instance.GetFile(img.FileId);
                var imageUrl = file != null ? FileManager.Instance.GetUrl(file) : "";

                <article class="pictur-card">
                    <a href="@Url.Action("Selected", "Image", new { id = img.ImageId })" class="pictur-card-link">
                        <div class="pictur-image-frame">
                            <img src="@imageUrl" alt="Kép" class="pictur-thumb" loading="lazy" />
                        </div>

                        <div class="pictur-card-meta">
                            <span class="pictur-swatch" style="background-color: @img.TopColorHex;" title="Domináns szín: @img.TopColorHex"></span>
                            <span>@img.TopColorHex</span>
                        </div>
                    </a>
                </article>
            }
        </div>
    }
    else
    {
        <div class="pictur-empty">
            <h2>Nincsenek még feltöltött képei.</h2>
            <a href="@Url.Action("Edit", "Image")" class="pictur-button">Kezdje el a feltöltést</a>
        </div>
    }
</div>